            { "fieldId": "content_type", "fieldValue": "story" },
            { "fieldId": "sublimated_url", "fieldValue": "={{ 'PLACEHOLDER_SUPABASE_URL/storage/v1/object/public/social-engine/' + $('Build Sublimation Prompt').first().json.client_slug + '/sublimated/' + $('Build Sublimation Prompt').first().json.fileName }}" },
            { "fieldId": "sublimation_prompt", "fieldValue": "={{ $('Build Sublimation Prompt').first().json.prompt }}" },
            { "fieldId": "sublimation_model", "fieldValue": "gpt-image-1" },
            { "fieldId": "caption", "fieldValue": "={{ ($json.output || {}).caption || $json.caption || '' }}" },
            { "fieldId": "cta", "fieldValue": "={{ ($json.output || {}).cta || $json.cta || '' }}" },
            { "fieldId": "caption_model", "fieldValue": "gpt-4o" },
            { "fieldId": "status", "fieldValue": "pending_review" },
            { "fieldId": "batch_id", "fieldValue": "={{ $('Split Story Slots').first().json.batch_id }}" },
            { "fieldId": "batch_week", "fieldValue": "={{ $('Split Story Slots').first().json.batch_week }}" },
            { "fieldId": "scheduled_at", "fieldValue": "={{ $('Split Story Slots').first().json.scheduled_at }}" }
          ]
        }
      },
      "credentials": {
