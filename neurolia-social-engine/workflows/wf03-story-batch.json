    {
      "id": "cd04",
      "name": "Calculate Week Range",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [840, 300],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const c = $json;\nconst now = new Date();\nconst day = now.getDay();\nconst dM = day === 0 ? 1 : (8 - day);\nconst mon = new Date(now.getFullYear(), now.getMonth(), now.getDate() + dM);\nconst sun = new Date(mon.getFullYear(), mon.getMonth(), mon.getDate() + 6);\nconst fmt = d => d.toISOString().split('T')[0];\nreturn [{ json: { client_id: c.id, client_slug: c.slug, client_name: c.name, next_monday: fmt(mon), next_sunday: fmt(sun), batch_id: 'batch-' + Date.now() + '-' + Math.random().toString(36).substring(2,8), batch_week: fmt(mon) } }];"
      }
    },
    {
      "id": "cd05",
      "name": "Fetch Story Slots",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1120, 300],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const httpRequest = globalThis.helpers.httpRequest;\nconst SB_URL = 'PLACEHOLDER_SUPABASE_URL';\nconst SB_KEY = 'PLACEHOLDER_SUPABASE_KEY';\nconst wr = $json;\nconst h = { apikey: SB_KEY, Authorization: 'Bearer ' + SB_KEY };\nlet slots = [];\ntry {\n  slots = await httpRequest({ method: 'GET', url: SB_URL + '/rest/v1/editorial_slots?client_id=eq.' + wr.client_id + '&content_type=eq.story&scheduled_date=gte.' + wr.next_monday + '&scheduled_date=lte.' + wr.next_sunday + '&order=scheduled_date.asc,scheduled_time.asc', headers: h });\n} catch(e) {}\nif (!Array.isArray(slots) || slots.length === 0) return [{ json: { _noData: true } }];\nreturn [{ json: { _noData: false, slots, slotsCount: slots.length, client_id: wr.client_id, client_slug: wr.client_slug, batch_id: wr.batch_id, batch_week: wr.batch_week } }];"
      }
    },
    {
      "id": "if06",
      "name": "IF Slots Found",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [1400, 300],
      "parameters": {
        "conditions": {
          "options": {
            "version": 2,
            "leftValue": "",
            "caseSensitive": true,
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "cond1",
              "leftValue": "={{ $json._noData }}",
              "rightValue": "",
              "operator": {
                "type": "boolean",
                "operation": "false",
                "singleValue": true
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      }
    },
    {
      "id": "sb07",
      "name": "Fetch Brand Platform",
      "type": "n8n-nodes-base.supabase",
      "typeVersion": 1,
      "position": [1680, 200],
      "parameters": {
        "resource": "row",
        "operation": "getAll",
        "tableId": "brand_platforms",
        "returnAll": true,
        "filterType": "manual",
        "matchType": "allFilters",
        "filters": {
          "conditions": [
            {
              "keyName": "client_id",
              "condition": "eq",
              "keyValue": "={{ $json.client_id }}"
            }
          ]
        }
      },
      "credentials": {
        "supabaseApi": {
          "id": "PLACEHOLDER",
          "name": "Supabase Social Engine"
        }
      }
    },
    {
      "id": "cd08",
      "name": "Assign Photos to Slots",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1960, 200],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const httpRequest = globalThis.helpers.httpRequest;\nconst SB_URL = 'PLACEHOLDER_SUPABASE_URL';\nconst SB_KEY = 'PLACEHOLDER_SUPABASE_KEY';\nconst data = $('Fetch Story Slots').first().json;\nconst h = { apikey: SB_KEY, Authorization: 'Bearer ' + SB_KEY };\nlet photos = [];\ntry {\n  photos = await httpRequest({ method: 'GET', url: SB_URL + '/rest/v1/uploads?client_id=eq.' + data.client_id + '&status=in.(new,assigned)', headers: h });\n} catch(e) {}\nif (!photos || photos.length === 0) return [];\nconst slots = data.slots || [];\nconst results = [];\nfor (let i = 0; i < slots.length; i++) {\n  const slot = slots[i];\n  let photo = photos.find(p => p.slot_id === slot.id);\n  if (!photo) photo = photos[i % photos.length];\n  results.push({ json: { slot_id: slot.id, slot, photo_url: photo.original_url, upload_id: photo.id, client_id: data.client_id, client_slug: data.client_slug, batch_id: data.batch_id, batch_week: data.batch_week, scheduled_at: slot.scheduled_date + 'T' + slot.scheduled_time } });\n}\nreturn results.length > 0 ? results : [];"
      }
    },
    {
      "id": "sp09",
      "name": "Split Story Slots",
      "type": "n8n-nodes-base.splitInBatches",
      "typeVersion": 3,
