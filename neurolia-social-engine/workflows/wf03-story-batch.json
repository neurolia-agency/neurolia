    {
      "id": "cd11",
      "name": "Build Sublimation Prompt",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2800, 200],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const item = $('Split Story Slots').first().json;\nconst slot = item.slot;\nconst brand = $('Fetch Brand Platform').first().json;\nconst p = 'Retouche legerement cette photo et incruste le texte suivant pour une story Instagram.\\n\\nCHARTE GRAPHIQUE :\\n- Couleur principale : ' + (brand.primary_color || '#000000') + '\\n- Couleurs secondaires : ' + ((brand.secondary_colors || []).join(', ')) + '\\n- Police principale : ' + (brand.font_primary || 'sans-serif moderne') + '\\n\\nDIRECTION VISUELLE :\\n' + (slot.visual_direction || 'Retouche legere.') + '\\n\\nTEXTE A INCRUSTER :\\n\"' + (slot.story_text || '') + '\"\\n\\nREGLES TEXTE :\\n- Police : ' + (brand.font_primary || 'sans-serif') + '\\n- Couleur : contraste fort\\n- Position : centre-bas\\n- Fond semi-transparent si necessaire\\n\\nMODE : Retouche legere. Dimensions : 1080x1920 (9:16).';\nreturn [{ json: { prompt: p, mode: 'light', model: 'gpt-image-1', slot_id: item.slot_id, upload_id: item.upload_id, client_id: item.client_id, client_slug: item.client_slug, batch_id: item.batch_id, batch_week: item.batch_week, scheduled_at: item.scheduled_at, fileName: 'story-' + item.slot_id.substring(0, 8) + '.png' }, binary: $input.first().binary }];"
      }
    },
    {
      "id": "oa12",
      "name": "Agent DA Story",
      "type": "@n8n/n8n-nodes-langchain.openAi",
