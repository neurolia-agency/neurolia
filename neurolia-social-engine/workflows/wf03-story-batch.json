          "id": "PLACEHOLDER",
          "name": "Supabase Social Engine"
        }
      }
    },
    {
      "id": "cd17",
      "name": "Update Uploads Status",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2520, 600],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const httpRequest = globalThis.helpers.httpRequest;\nconst SB_URL = 'PLACEHOLDER_SUPABASE_URL';\nconst SB_KEY = 'PLACEHOLDER_SUPABASE_KEY';\nconst h = { apikey: SB_KEY, Authorization: 'Bearer ' + SB_KEY, 'Content-Type': 'application/json', Prefer: 'return=minimal' };\nconst items = $('Assign Photos to Slots').all();\nconst ids = [...new Set(items.map(i => i.json.upload_id).filter(Boolean))];\nfor (const uid of ids) {\n  try { await httpRequest({ method: 'PATCH', url: SB_URL + '/rest/v1/uploads?id=eq.' + uid, headers: h, body: JSON.stringify({ status: 'processed' }) }); } catch(e) {}\n}\nreturn [{ json: { updated: ids.length } }];"
      }
    },
