      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [2520, 200],
      "parameters": {
        "method": "GET",
        "url": "={{ $('Split Story Slots').first().json.photo_url }}",
        "sendHeaders": true,
