    {
      "id": "cd14",
      "name": "Build Caption Prompt",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [3640, 200],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const httpRequest = globalThis.helpers.httpRequest;\nconst SB_URL = 'PLACEHOLDER_SUPABASE_URL';\nconst SB_KEY = 'PLACEHOLDER_SUPABASE_KEY';\nconst item = $('Split Story Slots').first().json;\nconst slot = item.slot;\nconst brand = $('Fetch Brand Platform').first().json;\nconst client = $('Split Clients').first().json;\nconst h = { apikey: SB_KEY, Authorization: 'Bearer ' + SB_KEY };\nlet recent = [];\ntry { recent = await httpRequest({ method: 'GET', url: SB_URL + '/rest/v1/content_queue?client_id=eq.' + item.client_id + '&status=eq.published&content_type=eq.story&order=created_at.desc&limit=10&select=caption,cta', headers: h }); } catch(e) {}\nconst caps = (recent || []).map((c, i) => (i+1) + '. ' + (c.caption || '').substring(0, 80)).join('\\n');\nconst systemPrompt = 'Tu es un redacteur social media expert en stories Instagram.\\nCaption courte (20-40 mots), percutante, directe.\\nJSON : { \"caption\": \"string\", \"cta\": \"string\" }\\nCoherente avec le texte image : \"' + (slot.story_text || '') + '\"\\nStyle : ' + (slot.caption_style || 'exclamatif') + '\\nEmojis : 1-2 max';\nconst userPrompt = 'Marque : ' + client.name + '\\nTon : ' + (brand.tone_of_voice || '') + '\\nTheme : ' + (slot.theme || '') + '\\nAngle : ' + (slot.angle || '') + '\\nStyle : ' + (slot.caption_style || '') + '\\nTexte story : \"' + (slot.story_text || '') + '\"\\n\\nDernieres captions :\\n' + (caps || 'Premiere.') + '\\n\\nCaption story (20-40 mots). JSON : { \"caption\", \"cta\" }';\nreturn [{ json: { systemPrompt, userPrompt, client_id: item.client_id } }];"
      }
    },
