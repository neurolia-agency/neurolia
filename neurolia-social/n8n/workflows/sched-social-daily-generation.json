      "parameters": {
        "jsCode": "const now = new Date();\nconst today = now.toISOString().split('T')[0];\nconst tomorrow = new Date(now.getTime() + 24 * 60 * 60 * 1000).toISOString().split('T')[0];\n\nreturn [{ json: { today, tomorrow, now: now.toISOString() } }];"
      },
