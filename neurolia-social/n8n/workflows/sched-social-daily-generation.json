        "query": "SELECT id, storage_path, tags FROM visual_assets WHERE restaurant_id = '={{ $json.restaurant_id }}' AND tags && ARRAY['={{ $json.content_type }}'] ORDER BY used_count ASC, uploaded_at DESC LIMIT 1",
