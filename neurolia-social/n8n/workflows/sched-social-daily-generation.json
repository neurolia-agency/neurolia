    {
      "parameters": {
        "jsCode": "const brand = $('Call Brand Memory Assembly').first().json;\nconst lastPosts = $('Fetch Last 10 Posts').all();\nconst asset = $('Select Visual Asset').first().json;\nconst weather = $('Get Weather Today').first().json;\nconst post = $('Loop Over Posts').first().json;\n\nconst systemPrompt = `Tu es un copywriter expert en réseaux sociaux pour la restauration. Tu écris des captions engageantes, authentiques et variées.\n\nRÈGLES ABSOLUES:\n- Écris en français, vouvoiement interdit (tutoiement ou impersonnel)\n- Ne commence JAMAIS par un emoji\n- Varie la longueur : parfois 2 lignes, parfois 6 lignes\n- Inclus des hashtags pertinents (5-8 max)\n- Adapte le ton à la plateforme\n- Réponds en JSON valide uniquement`;\n\nconst prompt = `MARQUE: ${brand.summary || post.name}\n\nTYPE DE POST: ${post.content_type}\nFORMAT: ${post.format}\nBRIEF CRÉATIF: ${post.creative_brief}\nPLATEFORMES: ${(post.platforms || []).join(', ')}\n\nMÉTÉO: ${weather.current_weather ? weather.current_weather.temperature + '°C' : 'Non disponible'}\n\nHOOKS ET STRUCTURES DÉJÀ UTILISÉS (NE PAS RÉPÉTER):\n${lastPosts.map(p => `- ${p.json.hook_type}/${p.json.structure_type}`).join('\\n') || 'Aucun historique'}\n\nGénère le contenu au format JSON:\n{\n  \"caption\": \"Le texte du post\",\n  \"hashtags\": [\"#tag1\", \"#tag2\"],\n  \"hook_type\": \"question|affirmation|mise_en_scene|temoignage|coulisses|defi|chiffre\",\n  \"structure_type\": \"hook_description_cta|contexte_revelation_invitation|question_reponse|story_mini\",\n  \"caption_length\": \"court|moyen|long\"\n}`;\n\nreturn [{ json: { system_prompt: systemPrompt, prompt, max_tokens: 1024, temperature: 0.8, post_id: post.id, restaurant_id: post.restaurant_id, asset_id: asset ? asset.id : null, asset_path: asset ? asset.storage_path : null } }];"
      },
      "id": "c9d0e1f2-a3b4-5c6d-7e8f-9a0b1c2d3e4f",
      "name": "Build Caption Prompt",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2500,
        200
      ]
    },
    {
      "parameters": {
        "workflowId": "CLAUDE_API_WORKFLOW_ID",
        "fieldsUi": {
          "values": [
            {
              "name": "system_prompt",
              "value": "={{ $json.system_prompt }}"
            },
            {
              "name": "prompt",
              "value": "={{ $json.prompt }}"
            },
            {
              "name": "max_tokens",
              "value": "={{ $json.max_tokens }}"
            },
            {
              "name": "temperature",
              "value": "={{ $json.temperature }}"
            }
          ]
        }
      },
      "id": "d0e1f2a3-b4c5-6d7e-8f9a-0b1c2d3e4f5a",
      "name": "Call Claude Caption",
      "type": "n8n-nodes-base.executeWorkflow",
      "typeVersion": 1,
      "position": [
        2750,
        200
      ]
    },
    {
      "parameters": {
        "jsCode": "const response = $input.first().json;\nconst promptData = $('Build Caption Prompt').first().json;\n\nlet parsed;\ntry {\n  const content = response.content || response.response || response;\n  parsed = typeof content === 'string' ? JSON.parse(content) : content;\n} catch (e) {\n  throw new Error('Failed to parse Claude response: ' + e.message);\n}\n\nreturn [{\n  json: {\n    caption: parsed.caption,\n    hashtags: parsed.hashtags || [],\n    hook_type: parsed.hook_type,\n    structure_type: parsed.structure_type,\n    caption_length: parsed.caption_length,\n    post_id: promptData.post_id,\n    restaurant_id: promptData.restaurant_id,\n    asset_id: promptData.asset_id,\n    asset_path: promptData.asset_path\n  }\n}];"
      },
      "id": "e1f2a3b4-c5d6-7e8f-9a0b-1c2d3e4f5a6b",
      "name": "Parse Caption Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        3000,
        200
      ]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "=UPDATE content_calendar SET caption = '{{ $json.caption.replace(/'/g, \"''\") }}', hashtags = '{{ \"{\" + $json.hashtags.join(\",\") + \"}\" }}', hook_type = '{{ $json.hook_type }}', structure_type = '{{ $json.structure_type }}', caption_length = '{{ $json.caption_length }}', media_paths = ARRAY['{{ $json.asset_path }}'], status = 'ready', updated_at = NOW() WHERE id = '{{ $json.post_id }}'",
        "options": {}
      },
