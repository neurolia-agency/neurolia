      },
      "id": "e1f2a3b4-c5d6-7890-e1f2-a3b4c5d67890",
      "name": "Log Publication",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [
        2500,
        200
      ],
