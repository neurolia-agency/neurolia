    {
      "parameters": {
        "amount": 1,
        "unit": "seconds"
      },
      "id": "f8a9b0c1-d2e3-4f4a-5b6c-7d8e9f0a1b2c",
      "name": "Wait Between API Calls",
      "type": "n8n-nodes-base.wait",
      "typeVersion": 1.1,
      "position": [
        3750,
        200
      ],
      "webhookId": "wait-analytics-batch"
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst totals = {\n  total_posts: items.length,\n  total_impressions: 0,\n  total_reach: 0,\n  total_engagement: 0,\n  avg_engagement_rate: 0,\n  avg_performance_score: 0\n};\n\nitems.forEach(item => {\n  const metrics = item.json.metrics || {};\n  totals.total_impressions += metrics.impressions || 0;\n  totals.total_reach += metrics.reach || 0;\n  totals.total_engagement += (metrics.likes || 0) + (metrics.comments || 0) + (metrics.shares || 0) + (metrics.saves || 0);\n  totals.avg_engagement_rate += item.json.engagement_rate || 0;\n  totals.avg_performance_score += item.json.performance_score || 0;\n});\n\nif (items.length > 0) {\n  totals.avg_engagement_rate /= items.length;\n  totals.avg_performance_score /= items.length;\n}\n\nreturn totals;",
        "options": {}
      },
      "id": "a9b0c1d2-e3f4-4a5b-6c7d-8e9f0a1b2c3d",
      "name": "Aggregate Daily Stats",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1500,
