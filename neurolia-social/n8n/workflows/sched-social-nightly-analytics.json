    {
      "parameters": {
        "jsCode": "const sevenDaysAgo = new Date();\nsevenDaysAgo.setDate(sevenDaysAgo.getDate() - 7);\nreturn { seven_days_ago: sevenDaysAgo.toISOString() };"
      },
      "id": "b2c3d4e5-f6a7-4b8c-9d0e-1f2a3b4c5d6e",
      "name": "Calculate Date Range",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        500,
        300
      ]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT pp.id, pp.content_id, pp.platform, pp.external_post_id, pp.published_at,\n       cc.restaurant_id, sa.access_token, sa.account_id\nFROM post_publications pp\nJOIN content_calendar cc ON pp.content_id = cc.id\nJOIN social_accounts sa ON sa.restaurant_id = cc.restaurant_id AND sa.platform = pp.platform\nWHERE pp.published_at >= NOW() - INTERVAL '7 days'\nORDER BY pp.published_at DESC"
      },
      "id": "c3d4e5f6-a7b8-4c9d-0e1f-2a3b4c5d6e7f",
      "name": "Fetch Recent Publications",
      "type": "n8n-nodes-base.postgres",
