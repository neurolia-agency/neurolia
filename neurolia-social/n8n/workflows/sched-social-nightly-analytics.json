          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "d4e5f6a7-b8c9-4d0e-1f2a-3b4c5d6e7f8a",
              "leftValue": "={{ $json.id }}",
              "rightValue": "",
              "operator": {
