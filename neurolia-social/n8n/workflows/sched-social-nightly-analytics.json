    {
      "parameters": {
        "method": "GET",
        "url": "=https://graph.facebook.com/v21.0/{{ $json.external_post_id }}/insights?metric=impressions,reach,saved,engagement&access_token={{ $json.access_token }}",
        "options": {
          "retry": {
            "maxRetries": 3
          }
        }
      },
      "id": "c9d0e1f2-a3b4-4c5d-6e7f-8a9b0c1d2e3f",
      "name": "Fetch Instagram Insights",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        2000,
        100
      ]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "=https://graph.facebook.com/v21.0/{{ $json.external_post_id }}/insights?metric=post_impressions,post_engaged_users,post_clicks&access_token={{ $json.access_token }}",
        "options": {
          "retry": {
            "maxRetries": 3
          }
        }
      },
      "id": "d0e1f2a3-b4c5-4d6e-7f8a-9b0c1d2e3f4a",
      "name": "Fetch Facebook Insights",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        2000,
        200
      ]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "=https://app.ayrshare.com/api/analytics/post?id={{ $json.external_post_id }}",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "options": {
          "retry": {
            "maxRetries": 3
          }
        }
      },
      "id": "e1f2a3b4-c5d6-4e7f-8a9b-0c1d2e3f4a5b",
      "name": "Fetch TikTok Analytics",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        2000,
        300
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "CREDENTIAL_ID",
          "name": "Ayrshare API"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const item = $json;\nconst pubDetails = $('Get Publication Details').first().json;\nconst platform = pubDetails.platform;\nlet metrics = { impressions: 0, reach: 0, likes: 0, comments: 0, shares: 0, saves: 0, video_views: 0 };\n\nif (platform === 'instagram' || platform === 'facebook') {\n  const data = item.data || [];\n  data.forEach(m => {\n    if (m.name === 'impressions' || m.name === 'post_impressions') metrics.impressions = m.values?.[0]?.value || 0;\n    if (m.name === 'reach') metrics.reach = m.values?.[0]?.value || 0;\n    if (m.name === 'saved') metrics.saves = m.values?.[0]?.value || 0;\n    if (m.name === 'engagement' || m.name === 'post_engaged_users') metrics.likes = m.values?.[0]?.value || 0;\n  });\n} else if (platform === 'tiktok') {\n  metrics.video_views = item.viewCount || 0;\n  metrics.likes = item.likeCount || 0;\n  metrics.comments = item.commentCount || 0;\n  metrics.shares = item.shareCount || 0;\n  metrics.impressions = item.viewCount || 0;\n  metrics.reach = item.viewCount || 0;\n}\n\nreturn { ...pubDetails, metrics };",
        "options": {}
      },
      "id": "a3b4c5d6-e7f8-4a9b-0c1d-2e3f4a5b6c7d",
      "name": "Normalize Metrics",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2500,
        200
      ]
    },
    {
      "parameters": {
        "jsCode": "const metrics = $json.metrics || {};\nconst engagement = (metrics.likes || 0) + (metrics.comments || 0) + (metrics.shares || 0) + (metrics.saves || 0);\nconst impressions = Math.max(metrics.impressions || 1, 1);\nconst engagement_rate = (engagement / impressions) * 100;\n\nreturn { ...$json, engagement_rate };"
      },
      "id": "b4c5d6e7-f8a9-4b0c-1d2e-3f4a5b6c7d8e",
      "name": "Calculate Engagement Rate",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2750,
        200
      ]
    },
    {
      "parameters": {
        "jsCode": "const engagement_rate = $json.engagement_rate || 0;\nconst metrics = $json.metrics || {};\nconst impressions = Math.max(metrics.impressions || 1, 1);\nconst reach = metrics.reach || 0;\nconst performance_score = (engagement_rate * 0.6) + ((reach / impressions) * 0.4 * 100);\n\nreturn { ...$json, performance_score };"
      },
      "id": "c5d6e7f8-a9b0-4c1d-2e3f-4a5b6c7d8e9f",
      "name": "Calculate Performance Score",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        3000,
        200
      ]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "=INSERT INTO post_analytics (publication_id, impressions, reach, likes, comments, shares, saves, video_views, engagement_rate, performance_score, collected_at)\nVALUES ('{{ $json.publication_id }}', {{ $json.metrics.impressions }}, {{ $json.metrics.reach }}, {{ $json.metrics.likes }}, {{ $json.metrics.comments }}, {{ $json.metrics.shares }}, {{ $json.metrics.saves }}, {{ $json.metrics.video_views }}, {{ $json.engagement_rate }}, {{ $json.performance_score }}, NOW())\nON CONFLICT (publication_id, collected_at) DO UPDATE SET\n  impressions = EXCLUDED.impressions,\n  reach = EXCLUDED.reach,\n  likes = EXCLUDED.likes,\n  comments = EXCLUDED.comments,\n  shares = EXCLUDED.shares,\n  saves = EXCLUDED.saves,\n  video_views = EXCLUDED.video_views,\n  engagement_rate = EXCLUDED.engagement_rate,\n  performance_score = EXCLUDED.performance_score"
      },
      "id": "d6e7f8a9-b0c1-4d2e-3f4a-5b6c7d8e9f0a",
      "name": "Upsert Analytics",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [
        3250,
        200
      ],
      "credentials": {
        "postgres": {
          "id": "CREDENTIAL_ID",
          "name": "Supabase Postgres"
        }
      }
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "=INSERT INTO generation_log (content_id, restaurant_id, generation_type, created_at) VALUES ('{{ $json.content_id }}', '{{ $json.restaurant_id }}', 'analytics_collection', NOW())"
      },
      "id": "e7f8a9b0-c1d2-4e3f-4a5b-6c7d8e9f0a1b",
      "name": "Log Analytics Collection",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [
        3500,
        200
      ],
      "credentials": {
        "postgres": {
          "id": "CREDENTIAL_ID",
          "name": "Supabase Postgres"
        }
