        "jsCode": "return {\n  publication_id: $json.id,\n  content_id: $json.content_id,\n  platform: $json.platform,\n  external_post_id: $json.external_post_id,\n  restaurant_id: $json.restaurant_id,\n  access_token: $json.access_token,\n  account_id: $json.account_id\n};",
        "options": {}
